{% extends 'base.html.twig' %}

{% block title %}Créer un compte{% endblock %}

{% block body %}
<main style="max-width:480px;margin:3rem auto;font-family:system-ui,sans-serif;color:#0f172a">
    <h1 style="margin-top:0">Créer un compte</h1>

    {% for label, messages in app.flashes(['error', 'success']) %}
        {% for msg in messages %}
            <div style="padding:.6rem .8rem;margin-bottom:1rem;border-radius:.375rem;
                        background:{{ label == 'error' ? '#fee2e2' : '#dcfce7' }};
                        color:{{ label == 'error' ? '#991b1b' : '#14532d' }}">
                {{ msg }}
            </div>
        {% endfor %}
    {% endfor %}

    <form method="post" action="{{ path('app_register') }}">
        <label style="display:block;margin-bottom:1rem">
            Email
            <input type="email" name="email" value="{{ last_email|default('') }}" required autofocus
                   style="display:block;width:100%;padding:.5rem;border:1px solid #d1d5db;border-radius:.375rem">
        </label>
        <label style="display:block;margin-bottom:1rem">
            Nom à afficher
            <input type="text" name="display_name" value="{{ last_display_name|default('') }}"
                   style="display:block;width:100%;padding:.5rem;border:1px solid #d1d5db;border-radius:.375rem">
        </label>
        <label style="display:block;margin-bottom:1rem">
            Mot de passe (8 caractères minimum)
            <input type="password" name="password" required minlength="8"
                   style="display:block;width:100%;padding:.5rem;border:1px solid #d1d5db;border-radius:.375rem">
        </label>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('register') }}">
        <button type="submit"
                style="background:#2563eb;color:#fff;padding:.6rem 1.2rem;border:0;border-radius:.375rem;cursor:pointer;font-size:1rem">
            S'inscrire
        </button>
    </form>

    <p style="margin-top:1.5rem">
        Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a>
    </p>
</main>
{% endblock %}
