# =============================================================================
#  Project environment — copy to .env and adjust as needed
# =============================================================================

# --- Host ports --------------------------------------------------------------
HTTP_HOST_PORT=8080
POSTGRES_HOST_PORT=5433
MONGO_HOST_PORT=27018
MONGO_EXPRESS_PORT=8081

# --- App user (matches host UID/GID for cross-platform bind-mount writes) ----
# On Linux/macOS run: `id -u` / `id -g`. On Windows leave defaults.
APP_UID=1000
APP_GID=1000

# --- Symfony -----------------------------------------------------------------
APP_ENV=dev
APP_SECRET=change-me-to-a-random-32+-char-string

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_DB=baas
POSTGRES_USER=baas
# Password lives in ./secrets/postgres_password.txt (Docker secret),
# but Symfony's DATABASE_URL also needs the literal password — keep them in sync.
POSTGRES_PASSWORD=baas_app_pwd

# --- MongoDB -----------------------------------------------------------------
MONGO_DB=baas
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change_this_root_password
MONGO_APP_USER=baas
MONGO_APP_PASSWORD=baas_app_pwd

# --- JWT (Lexik) -------------------------------------------------------------
JWT_PASSPHRASE=change_me_jwt_passphrase

# --- CORS (regex) ------------------------------------------------------------
CORS_ALLOW_ORIGIN=^https?://(localhost|127\.0\.0\.1)(:[0-9]+)?$
